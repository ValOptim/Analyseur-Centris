{
  "manifest_version": 3,
  "name": "Analyseur Centris",
  "version": "0.1.0",
  "description": "Analyse financiere preliminaire des immeubles sur Centris.",
  "content_scripts": [
    {
      "matches": ["https://www.centris.ca/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["https://www.centris.ca/*"]
}
